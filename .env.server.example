# Copy to .env.server and fill real values

# Public
PUBLIC_HOST=your-domain.example.com
GATEWAY_PORT=8080

# PostgreSQL
POSTGRES_USER=furniture
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=furniture
POSTGRES_PORT=5432

# JWT / Auth
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
JWT_ACCESS_TTL_MINUTES=120
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
AUTH_BOOTSTRAP_ROLES=admin,catalog:write,planner:write,cutting:run,assets:write

# RabbitMQ
RABBITMQ_USER=furniture
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_RMQ_PASSWORD
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_EXCHANGE_EVENTS=furniture.events

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=furniture-assets
AWS_REGION=us-east-1
CDN_PUBLIC_BASE_URL=
