# Copy to .env in project root on the server:
#   cp deploy/server.env.sample .env && nano .env

# Site URL (for docs / future links)
PUBLIC_HOST=45.11.26.79

# Port 8001 is used by a host uvicorn on this VPS — gateway on 8002
GATEWAY_PORT=8002
GATEWAY_PORT_MAPPING=0.0.0.0:8002:8000

# PostgreSQL — only localhost on server (not exposed to internet)
POSTGRES_PORT_MAPPING=127.0.0.1:5432:5432
POSTGRES_USER=furniture
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=furniture

# JWT / Auth (use separate strong secrets, not SSH password)
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
JWT_ACCESS_TTL_MINUTES=120
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
AUTH_BOOTSTRAP_ROLES=admin,catalog:write,planner:write,cutting:run,assets:write

# RabbitMQ (internal; ports for optional admin access)
RABBITMQ_USER=furniture
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_RMQ_PASSWORD
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_EXCHANGE_EVENTS=furniture.events

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=furniture-assets
AWS_REGION=us-east-1
CDN_PUBLIC_BASE_URL=
