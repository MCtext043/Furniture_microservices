#
# This file is uploaded to the server as .env (gitignored).

PUBLIC_HOST=45.11.26.79
GATEWAY_PORT=8002
GATEWAY_PORT_MAPPING=0.0.0.0:8002:8000
POSTGRES_PORT_MAPPING=127.0.0.1:5432:5432

POSTGRES_USER=furniture
POSTGRES_PASSWORD=your_strong_db_password
